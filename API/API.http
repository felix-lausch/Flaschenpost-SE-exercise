@host = http://localhost:5076
@DataUrl = https://flapotest.blob.core.windows.net/test/ProductData.json

### All results combined
GET {{host}}/api/products/all?url={{DataUrl}}
Accept: application/json

### Most expensive and cheapest beer per litre
GET {{host}}/api/products/most-expensive-cheapest?url={{DataUrl}}
Accept: application/json

### Beers costing exactly €17.99 (sorted by price/litre)
GET {{host}}/api/products/beers-at-1799?url={{DataUrl}}
Accept: application/json

### Product with most bottles
GET {{host}}/api/products/most-bottles?url={{DataUrl}}
Accept: application/json

### Fetch source data
GET https://flapotest.blob.core.windows.net/test/ProductData.json
Accept: application/json

###